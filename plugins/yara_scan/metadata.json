{
  "schema_version": "1.0",
  "plugin": {
    "id": "yara_scan",
    "name": "YARA Malware Scanner",
    "version": "1.0.0",
    "author": "SecuScan Team",
    "description": "Pattern matching tool for malware detection and binary analysis.",
    "category": "forensics",
    "tags": ["malware", "forensics", "yara"],
    "icon": "bug",
    "documentation_url": "https://virustotal.github.io/yara/"
  },
  "execution": {
    "engine": "cli",
    "command_template": [
      "yara", "-r", "{{rules}}", "{{target}}"
    ],
    "timeout_seconds": 300,
    "container": {
      "required": true,
      "image": "secuscan/yara:latest"
    }
  },
  "fields": [
    {
      "id": "target",
      "label": "Target Path",
      "type": "string",
      "required": true,
      "description": "Local path to file or directory to scan."
    },
    {
      "id": "rules",
      "label": "YARA Rules Path",
      "type": "string",
      "required": true,
      "description": "Path to .yar rule file."
    }
  ],
  "presets": {
    "default": {
      "parameters": {},
      "safety_level": "safe"
    }
  },
  "safety": {
    "level": "moderate",
    "description": "Requires access to local files. Use only on trusted files."
  }
}
