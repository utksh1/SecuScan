{
  "schema_version": "1.0",
  "plugin": {
    "id": "joomscan",
    "name": "JoomScan (Joomla Scanner)",
    "version": "1.0.0",
    "author": "SecuScan Team",
    "description": "Joomla vulnerability scanner for detection and fingerprinting.",
    "category": "cms",
    "tags": ["joomla", "vuln-scan"],
    "icon": "joomla",
    "documentation_url": "https://github.com/OWASP/joomscan"
  },
  "execution": {
    "engine": "cli",
    "command_template": [
      "joomscan", "--url", "{{target}}", "--enumerate"
    ],
    "timeout_seconds": 600,
    "container": {
      "required": true,
      "image": "secuscan/joomscan:latest"
    }
  },
  "fields": [
    {
      "id": "target",
      "label": "Target URL",
      "type": "string",
      "required": true,
      "validation": {
        "pattern": "^https?://[a-zA-Z0-9.-]+(/.*)?$"
      }
    }
  ],
  "presets": {
    "default": {
      "parameters": {},
      "safety_level": "safe"
    }
  },
  "safety": {
    "level": "safe"
  }
}
