{
  "id": "kubernetes_scanner",
  "name": "K8s Scanner",
  "version": "1.0.0",
  "description": "Kubernetes cluster security assessment.",
  "long_description": "Kubernetes cluster security assessment.",
  "category": "vulnerability",
  "author": {
    "name": "SecuScan Contributors",
    "email": "dev@secuscan.local"
  },
  "license": "MIT",
  "icon": "🛠️",
  "engine": {
    "type": "cli",
    "binary": "python3"
  },
  "command_template": [
    "python3",
    "-c",
    "import sys;print('Kubernetes scan baseline checks');print('target='+sys.argv[1]);print('checks=rbac,networkpolicies,misconfig')",
    "{target}"
  ],
  "fields": [
    {
      "id": "target",
      "label": "Cluster Context",
      "type": "string",
      "required": true,
      "placeholder": "prod-cluster",
      "help": "Enter the Kubernetes cluster context name from your kubeconfig, for example prod-cluster."
    }
  ],
  "presets": {
    "default": {}
  },
  "output": {
    "format": "text",
    "parser": "custom"
  },
  "safety": {
    "level": "intrusive",
    "requires_consent": true,
    "consent_message": "Kubernetes assessments require cluster owner authorization.",
    "rate_limit": {
      "max_per_hour": 20,
      "max_concurrent": 1
    }
  },
  "dependencies": {
    "binaries": [
      "python3"
    ],
    "python_packages": [],
    "system_packages": []
  },
  "checksum": "c1188c318df1eb9160074f26cb4d6bc02cec49b65c97b1da0d3456f96e22640b"
}
