{
  "id": "volatility",
  "name": "Volatility",
  "version": "1.0.0",
  "description": "Memory forensics workflow using Volatility 3 plugins.",
  "long_description": "Runs Volatility 3 against memory dumps for process, module, and system artifact triage.",
  "category": "forensics",
  "author": {
    "name": "SecuScan Contributors",
    "email": "dev@secuscan.local"
  },
  "license": "MIT",
  "icon": "🧠",
  "engine": {
    "type": "cli",
    "binary": "volatility3"
  },
  "command_template": [
    "volatility3",
    "-f",
    "{target}",
    "{plugin_name}"
  ],
  "fields": [
    {
      "id": "target",
      "label": "Memory Dump Path",
      "type": "string",
      "required": true,
      "placeholder": "/tmp/memdump.raw",
      "help": "Absolute path to the raw memory image file to analyse (e.g. /tmp/memdump.raw). Supported formats include .raw, .mem, .vmem, and .lime."
    },
    {
      "id": "plugin_name",
      "label": "Volatility Plugin",
      "type": "string",
      "required": false,
      "default": "windows.pslist.PsList",
      "help": "Example: windows.info.Info, windows.pslist.PsList"
    }
  ],
  "presets": {
    "process_list": {
      "plugin_name": "windows.pslist.PsList"
    },
    "system_info": {
      "plugin_name": "windows.info.Info"
    }
  },
  "output": {
    "format": "text",
    "parser": "custom"
  },
  "safety": {
    "level": "intrusive",
    "requires_consent": true,
    "consent_message": "Memory forensics can expose sensitive in-memory data. Authorized handling is required.",
    "rate_limit": {
      "max_per_hour": 10,
      "max_concurrent": 1
    }
  },
  "dependencies": {
    "binaries": [
      "volatility3"
    ],
    "python_packages": [],
    "system_packages": []
  },
  "checksum": "886d2aa358ca55bb4bd49ec90ac5dcf0cc7d8962c21daeec78bd77128fc1f888"
}
