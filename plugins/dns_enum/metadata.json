{
  "id": "dns_enum",
  "name": "DNS Reconnaissance",
  "version": "1.0.0",
  "description": "Enumerate DNS records (A, MX, NS, SOA), attempt zone transfers, and brute-force subdomains using DNSRecon.",
  "long_description": "DNS Recon uses DNSRecon to inspect the DNS configuration of a target domain. Unlike subdomain discovery plugins (Amass, Subfinder), this plugin focuses on DNS record types and server misconfigurations \u2014 such as exposed zone transfers (AXFR) and missing SPF/DMARC records. Use this after identifying a target domain to understand its DNS infrastructure before deeper enumeration.",
  "category": "recon",
  "author": {
    "name": "SecuScan Contributors",
    "email": "dev@secuscan.local"
  },
  "license": "MIT",
  "icon": "\ud83d\udce6",
  "engine": {
    "type": "cli",
    "binary": "dnsrecon"
  },
  "command_template": [
    "dnsrecon",
    "-d",
    "{target}",
    "--if:type:then:-t:{type}"
  ],
  "fields": [
    {
      "id": "target",
      "label": "Domain",
      "type": "string",
      "required": true,
      "placeholder": "example.com",
      "help": "Target domain for DNS enumeration."
    },
    {
      "id": "type",
      "label": "Enum Type",
      "type": "select",
      "required": false,
      "default": "std",
      "options": [
        {
          "value": "std",
          "label": "Standard (A, MX, NS, SOA)"
        },
        {
          "value": "axfr",
          "label": "Zone Transfer (AXFR)"
        },
        {
          "value": "brt",
          "label": "Brute Force Subdomains"
        }
      ],
      "help": "Type of DNS enumeration to perform."
    }
  ],
  "presets": {
    "standard": {
      "type": "std"
    },
    "zone_transfer": {
      "type": "axfr"
    }
  },
  "output": {
    "format": "text",
    "parser": "custom"
  },
  "safety": {
    "level": "safe",
    "requires_consent": false,
    "rate_limit": {
      "max_per_hour": 30,
      "max_concurrent": 1
    }
  },
  "learning": {
    "difficulty": "intermediate",
    "estimated_duration": "1-3 minutes",
    "tutorial_url": "https://docs.secuscan.local/plugins/dns_enum"
  },
  "dependencies": {
    "binaries": [
      "dnsrecon"
    ],
    "python_packages": [],
    "system_packages": [
      "dnsrecon"
    ]
  },
  "docker_image": "darkoperator/dnsrecon:latest",
  "checksum": "4d52a0d59b109ada0c9c178f06c6135825a48f152cf613c35638fec5f6c6f382"
}
